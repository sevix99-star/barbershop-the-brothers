---
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/400-italic.css";
import "@fontsource/cormorant-garamond/500.css";
import "@fontsource/cormorant-garamond/500-italic.css";
import "@fontsource/cormorant-garamond/600.css";
import "@fontsource/cormorant-garamond/700.css";
import "@fontsource/dm-sans/400.css";
import "@fontsource/dm-sans/500.css";
import "@fontsource/dm-sans/600.css";
import cormorant700Url from "@fontsource/cormorant-garamond/files/cormorant-garamond-latin-700-normal.woff2?url";
import cormorant500Url from "@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-normal.woff2?url";
import dmSans400Url from "@fontsource/dm-sans/files/dm-sans-latin-400-normal.woff2?url";
import dmSans600Url from "@fontsource/dm-sans/files/dm-sans-latin-600-normal.woff2?url";
import "../styles/global.css";
import { getImage } from "astro:assets";
import { HERO_IMAGE } from "../config/images";
import { CONTACT } from "../config/contact";
import { t, type Lang } from "../i18n/utils";
import CookieBanner from "../components/CookieBanner.astro";
import FloatingBookCTA from "../components/FloatingBookCTA.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const title = t(lang, "meta.title");
const description = t(lang, "meta.description");
const baseUrl = "https://barbershopthebrothers.nl";
const canonicalUrl = `${baseUrl}/${lang}/`;
const locales: Record<Lang, string> = {
  nl: "nl_NL",
  en: "en_GB",
  pl: "pl_PL",
};

const heroPreload = await getImage({
  src: HERO_IMAGE,
  widths: [768, 1280, 1920],
  format: "avif",
  quality: 72,
});

const ogImageUrl = `${baseUrl}${heroPreload.src}`;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BarberShop",
  name: "Barbershop The Brothers",
  image: ogImageUrl,
  address: {
    "@type": "PostalAddress",
    streetAddress: "De Promesse 113",
    addressLocality: "Lelystad",
    postalCode: "8232 VZ",
    addressCountry: "NL",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 52.5079,
    longitude: 5.4749,
  },
  url: baseUrl,
  telephone: CONTACT.phone || CONTACT.whatsapp || undefined,
  email: CONTACT.email,
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Monday", opens: "12:00", closes: "18:00" },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "18:00",
    },
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "09:00", closes: "17:00" },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5.0",
    reviewCount: "109",
  },
  priceRange: "€10–€35",
  currenciesAccepted: "EUR",
  paymentAccepted: "Cash, Card",
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={cormorant700Url} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={cormorant500Url} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={dmSans400Url} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={dmSans600Url} />
    <script is:inline>
      (function(){var t=localStorage.getItem('barbershop-theme'),s=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';document.documentElement.setAttribute('data-theme',t||s)})();
    </script>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preload" as="image" href={heroPreload.src} type="image/avif" fetchpriority="high" imagesrcset={heroPreload.srcSet.attribute} imagesizes="100vw" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="nl" href={`${baseUrl}/nl/`} />
    <link rel="alternate" hreflang="en" href={`${baseUrl}/en/`} />
    <link rel="alternate" hreflang="pl" href={`${baseUrl}/pl/`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/nl/`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locales[lang]} />

    <meta name="theme-color" content="#0A0A0A" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />
  </head>
  <body class="bg-bg text-ink">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-gold focus:px-4 focus:py-2 focus:text-bg focus:outline-none">
      Skip to content
    </a>
    <slot />

    <CookieBanner lang={lang} />
    <FloatingBookCTA lang={lang} />
    <WhatsAppButton lang={lang} />

    <script>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("animate-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );
        document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
      } else {
        document.querySelectorAll("[data-animate]").forEach((el) => el.classList.add("animate-visible"));
      }
    </script>
  </body>
</html>
