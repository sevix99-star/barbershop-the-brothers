---
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div
  id="cookie-banner"
  role="dialog"
  aria-label="Cookie consent"
  aria-live="polite"
  class="fixed inset-x-0 top-0 z-[90] border-b border-line bg-bg/95 px-6 py-5 backdrop-blur-md"
  style="display:none"
>
  <div class="wrap flex flex-col items-start gap-4 md:flex-row md:items-center md:justify-between">
    <p class="max-w-[680px] text-[13px] leading-[1.65] text-ink-dim">
      {t(lang, "cookie.message")}
    </p>
    <div class="flex shrink-0 flex-wrap gap-3">
      <button
        id="cookie-decline"
        class="btn btn-ghost text-[12px]"
      >
        {t(lang, "cookie.decline")}
      </button>
      <button
        id="cookie-accept"
        class="btn btn-gold text-[12px]"
      >
        {t(lang, "cookie.accept")}
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById("cookie-banner");
  const acceptBtn = document.getElementById("cookie-accept");
  const declineBtn = document.getElementById("cookie-decline");

  function hideBanner() {
    if (banner) banner.style.display = "none";
  }

  function setConsent(value: "accepted" | "declined") {
    localStorage.setItem("cookie_consent", value);
    window.dispatchEvent(new CustomEvent("cookie-consent", { detail: value }));
    hideBanner();
  }

  if (!localStorage.getItem("cookie_consent") && banner) {
    requestAnimationFrame(() => { if (banner) banner.style.display = "block"; });
  }

  acceptBtn?.addEventListener("click", () => setConsent("accepted"));
  declineBtn?.addEventListener("click", () => setConsent("declined"));
</script>
