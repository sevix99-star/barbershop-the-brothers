---
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

/** Empty frame slots (layout only — no placeholder images). */
const frameCount = 12;
---

<section id="gallery" class="px-4 py-24 md:px-8" data-animate>
  <div class="mx-auto max-w-6xl">
    <h2 class="section-title section-title--left">{t(lang, "gallery.title")}</h2>

    <div
      class="mt-12 grid grid-cols-2 gap-2 md:grid-cols-3"
      role="presentation"
      aria-hidden="true"
    >
      {
        Array.from({ length: frameCount }).map(() => (
          <div class="group relative aspect-square overflow-hidden rounded-lg border border-dashed border-white/15 bg-white/[0.03] transition duration-300 hover:border-gold/35 hover:bg-white/[0.06]">
            <div
              class="pointer-events-none absolute inset-3 rounded-md border border-white/5 opacity-60"
              aria-hidden="true"
            />
          </div>
        ))
      }
    </div>

    <a
      href="https://www.instagram.com/barbershop.the.brothers.eb/"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex text-gold transition hover:text-gold-hover"
    >
      {t(lang, "gallery.instagram")}: @barbershop.the.brothers.eb
    </a>
  </div>
</section>
