---
import { getTranslations, t, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const images = getTranslations(lang).gallery.images;
---

<section id="gallery" class="px-4 py-24 md:px-8" data-animate>
  <div class="mx-auto max-w-6xl">
    <h2 class="section-title section-title--left">{t(lang, "gallery.title")}</h2>

    <div class="mt-12 grid grid-cols-2 gap-2 md:grid-cols-3">
      {
        images.map((image) => (
          <div class="group relative aspect-square overflow-hidden rounded-lg">
            <img
              src={image.src}
              alt={image.alt}
              class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
              loading="lazy"
              decoding="async"
              width="600"
              height="600"
            />
            <div class="absolute inset-0 bg-gold/10 opacity-0 transition group-hover:opacity-100"></div>
          </div>
        ))
      }
    </div>

    <a
      href="https://www.instagram.com/barbershop.the.brothers.eb/"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex text-gold transition hover:text-gold-hover"
      aria-label={`${t(lang, "gallery.instagram")} (opens in new tab)`}
    >
      {t(lang, "gallery.instagram")}: @barbershop.the.brothers.eb
    </a>
  </div>
</section>
