---
import { languages, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const allLangs = Object.entries(languages) as [Lang, string][];
---

<nav class="flex items-center border border-line p-[3px]" aria-label="Language switcher">
  {
    allLangs.map(([code, label]) => (
      <a
        href={`/${code}/`}
        data-lang-switch
        data-locale={code}
        class:list={[
          "font-cond text-[11px] px-[10px] py-[6px] tracking-[0.18em] uppercase transition-colors",
          lang === code
            ? "bg-gold text-bg"
            : "text-ink-dim hover:text-ink",
        ]}
        aria-label={`${label} (${code.toUpperCase()})`}
      >
        {code.toUpperCase()}
      </a>
    ))
  }
</nav>

<script>
  function setLocaleCookie(locale: string): void {
    document.cookie =
      `barbershop-locale=${locale}; path=/; max-age=31536000; SameSite=Lax`;
  }

  const switchLinks = document.querySelectorAll("[data-lang-switch]");
  switchLinks.forEach((link) => {
    link.addEventListener("click", (event) => {
      if (!(event.currentTarget instanceof HTMLAnchorElement)) return;
      const anchor = event.currentTarget;
      const locale = anchor.dataset.locale;
      if (locale) setLocaleCookie(locale);
      if (!window.location.hash) return;
      const url = new URL(anchor.href, window.location.origin);
      url.hash = window.location.hash;
      anchor.href = url.toString();
    });
  });
</script>
