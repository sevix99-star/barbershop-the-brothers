---
import { getTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tx = getTranslations(lang);
const reviews = tx.reviews.items;
const reviewsUrl = import.meta.env.PUBLIC_GOOGLE_REVIEWS_URL ?? "https://www.google.com/maps";
---

<section id="reviews" class="sec bg-[#0C0C0C]" data-animate>
  <div class="wrap">
    <div class="sec-head">
      <div>
        <div class="sec-num">
          <span class="tick" aria-hidden="true"></span>
          <span>{tx.reviews.number} —</span>
          <span>{tx.reviews.eyebrow}</span>
        </div>
        <h2 class="mt-[18px]">
          <span>{tx.reviews.headline.part1}</span><br />
          <em>{tx.reviews.headline.accent}</em>
        </h2>
      </div>
      <p class="lede">{tx.reviews.lede}</p>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
      {
        reviews.map((review) => (
          <article class="rcard relative overflow-hidden border border-line bg-surface p-11 pt-12">
            <span
              class="absolute left-7 top-3 font-serif italic text-gold"
              style="font-size:80px;line-height:1;opacity:0.45"
              aria-hidden="true">“</span>
            <div class="mb-4 tracking-[0.3em] text-gold" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="relative z-[1] font-serif text-[19px] italic leading-[1.55] tracking-[-0.005em] text-ink">
              {review.text}
            </p>
            <div class="mt-6 border-t border-line pt-4 font-cond text-[10px] uppercase tracking-[0.22em] text-ink-mute">
              <span class="text-ink">{review.name}</span>
              <span class="mx-2 text-ink-mute/50">·</span>
              <span>{review.date}</span>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-10 text-center">
      <a
        href={reviewsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="font-cond text-[12px] uppercase tracking-[0.22em] text-gold border-b border-gold pb-1 transition-opacity hover:opacity-80"
      >
        {tx.reviews.viewAll}
      </a>
    </div>
  </div>
</section>

<div class="rule" aria-hidden="true"></div>
