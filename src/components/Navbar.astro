---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import OpenStatus from "./OpenStatus.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const navLinks = [
  { href: "#home", key: "nav.home" },
  { href: "#services", key: "nav.services" },
  { href: "#prices", key: "nav.prices" },
  { href: "#gallery", key: "nav.gallery" },
  { href: "#booking", key: "nav.bookNow" },
];
---

<nav
  id="navbar"
  aria-label="Main navigation"
  class="nav sticky top-0 z-50 border-b border-line-2 bg-bg/80 transition-colors"
>
  <div class="mx-auto flex max-w-wrap items-center justify-between px-6 py-[18px] md:px-12">
    <a href={`/${lang}/#home`} class="flex items-center gap-[14px] text-ink">
      <span class="grid h-[34px] w-[34px] place-items-center border border-gold font-serif text-base italic text-gold">EB</span>
      <span class="h-[18px] w-px bg-line" aria-hidden="true"></span>
      <span class="font-serif text-xl tracking-wide">The Brothers</span>
    </a>

    <div class="hidden items-center gap-[34px] lg:flex">
      {
        navLinks.map((link) => (
          <a
            href={`/${lang}/${link.href}`}
            class="nav-link relative py-[6px] text-[12px] uppercase tracking-[0.22em] text-ink-dim transition-colors hover:text-ink"
          >
            {t(lang, link.key)}
          </a>
        ))
      }
    </div>

    <div class="hidden items-center gap-[18px] lg:flex">
      <OpenStatus lang={lang} variant="pill" />
      <LanguageSwitcher lang={lang} />
      <ThemeToggle lang={lang} />
      <a
        href={`/${lang}/#booking`}
        class="btn btn-gold"
      >
        {t(lang, "nav.appointment")} <span class="arrow">→</span>
      </a>
    </div>

    <button
      id="mobile-menu-button"
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center border border-line text-ink lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="pointer-events-none absolute inset-x-4 top-[74px] border border-line bg-surface-2 p-5 opacity-0 shadow-xl transition-all duration-300 lg:hidden"
  >
    <div class="flex flex-col gap-1">
      {
        navLinks.map((link) => (
          <a
            href={`/${lang}/${link.href}`}
            class="px-3 py-3 text-[12px] uppercase tracking-[0.22em] text-ink-dim transition hover:text-gold"
          >
            {t(lang, link.key)}
          </a>
        ))
      }
      <div class="flex items-center gap-3 pt-3">
        <LanguageSwitcher lang={lang} />
        <ThemeToggle lang={lang} />
      </div>
      <a
        href={`/${lang}/#booking`}
        class="btn btn-gold mt-3 justify-center"
      >
        {t(lang, "nav.appointment")} <span class="arrow">→</span>
      </a>
    </div>
  </div>
</nav>

<style>
  #navbar[data-scrolled="true"] {
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(12px) saturate(180%);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background: var(--color-gold);
    transition: right 0.35s ease;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    right: 0;
  }
</style>

<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  const links = menu?.querySelectorAll("a");

  const closeMenu = () => {
    menu?.classList.add("pointer-events-none", "opacity-0");
    button?.setAttribute("aria-expanded", "false");
  };
  const openMenu = () => {
    menu?.classList.remove("pointer-events-none", "opacity-0");
    button?.setAttribute("aria-expanded", "true");
  };

  let isOpen = false;
  button?.addEventListener("click", () => {
    isOpen = !isOpen;
    isOpen ? openMenu() : closeMenu();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && isOpen) {
      isOpen = false;
      closeMenu();
      button?.focus();
    }
  });

  links?.forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      closeMenu();
    });
  });

  window.addEventListener("hashchange", () => {
    isOpen = false;
    closeMenu();
  });

  document.addEventListener("click", (event) => {
    if (!menu || !button) return;
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (!menu.contains(target) && !button.contains(target)) {
      isOpen = false;
      closeMenu();
    }
  });

  const nav = document.getElementById("navbar");
  if (nav) nav.dataset.scrolled = "";
  const onScroll = () => {
    if (nav) nav.dataset.scrolled = window.scrollY > 0 ? "true" : "";
  };
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
