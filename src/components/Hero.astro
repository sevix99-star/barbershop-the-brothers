---
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section
  id="home"
  class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 pt-28 md:px-8"
>
  <!-- Lokalny plik w /public/gallery — bez zewnętrznego URL (np. Unsplash) -->
  <img
    src="/gallery/hero-banner.jpg"
    alt=""
    class="absolute inset-0 h-full w-full object-cover object-center"
    width="1920"
    height="1080"
    decoding="async"
    fetchpriority="high"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-bg/90 via-bg/65 to-bg" aria-hidden="true"></div>

  <div class="relative mx-auto flex max-w-4xl flex-col items-center text-center">
    <p class="hero-animate mb-4 text-sm uppercase tracking-[0.35em] text-text-primary/85" style="animation-delay: 0ms;">
      {t(lang, "hero.subline")}
    </p>
    <h1
      class="hero-animate font-heading text-5xl font-bold leading-tight text-text-primary md:text-7xl"
      style="animation-delay: 200ms;"
    >
      {t(lang, "hero.headline")}
    </h1>
    <div class="hero-animate mt-8 flex flex-wrap items-center justify-center gap-4" style="animation-delay: 400ms;">
      <a
        href={`/${lang}/#booking`}
        class="rounded-full bg-gold px-8 py-3 font-semibold text-bg transition hover:bg-gold-hover"
      >
        {t(lang, "hero.ctaPrimary")}
      </a>
      <a
        href={`/${lang}/#prices`}
        class="rounded-full border border-gold px-8 py-3 font-semibold text-gold transition hover:bg-gold/10"
      >
        {t(lang, "hero.ctaSecondary")}
      </a>
    </div>
    <div
      class="hero-animate mt-8 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-text-primary backdrop-blur-md shadow-lg"
      style="animation-delay: 600ms;"
    >
      ★ {t(lang, "hero.badge")}
    </div>
    <div class="hero-animate mt-4 flex items-center gap-2 text-text-primary/85" style="animation-delay: 600ms;">
      <svg class="h-5 w-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11z"></path>
        <circle cx="12" cy="10" r="2.5"></circle>
      </svg>
      <p>{t(lang, "hero.address")}</p>
    </div>
  </div>
</section>
