---
import { getTranslations, type Lang } from "../i18n/utils";
import { CONTACT, buildWhatsAppUrl } from "../config/contact";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tx = getTranslations(lang);

const dayKeys = [
  "monday",
  "tuesday",
  "wednesday",
  "thursday",
  "friday",
  "saturday",
  "sunday",
] as const;

const jsDayToKey: Record<number, (typeof dayKeys)[number]> = {
  1: "monday",
  2: "tuesday",
  3: "wednesday",
  4: "thursday",
  5: "friday",
  6: "saturday",
  0: "sunday",
};

const todayKey = jsDayToKey[new Date().getDay()];

const phone = CONTACT.phone;
const email = CONTACT.email;
const whatsappUrl = buildWhatsAppUrl(lang);
const whatsappDisplay = CONTACT.whatsapp;
const mapsEmbed = CONTACT.googleMapsEmbed;
const mapsDirections = CONTACT.googleMapsDirections;

const mapLabels: Record<Lang, string> = {
  nl: "Kaart laden (vereist cookies)",
  en: "Load map (requires cookies)",
  pl: "Załaduj mapę (wymaga cookies)",
};
---

<section id="location" class="sec" data-animate>
  <div class="wrap">
    <div class="sec-head">
      <div>
        <div class="sec-num">
          <span class="tick" aria-hidden="true"></span>
          <span>{tx.location.number} —</span>
          <span>{tx.location.eyebrow}</span>
        </div>
        <h2 class="mt-[18px]">
          <span>{tx.location.headline.part1}</span><br />
          <em>{tx.location.headline.accent}</em>
        </h2>
      </div>
      <p class="lede">{tx.location.lede}</p>
    </div>

    <div class="grid grid-cols-1 gap-0 border border-line md:grid-cols-[1fr_1fr]">
      <div class="bg-surface p-10 md:p-14">
        <div class="mb-6 font-cond text-[11px] uppercase tracking-[0.22em] text-gold">
          {tx.location.openingHours}
        </div>

        <ul class="mb-10 divide-y divide-line">
          {
            dayKeys.map((key) => {
              const isToday = key === todayKey;
              return (
                <li
                  class={`flex items-center justify-between py-[11px] font-cond text-[12px] uppercase tracking-[0.18em] ${isToday ? "text-gold" : "text-ink"}`}
                >
                  <span class="flex items-center gap-3">
                    {isToday ? <span class="live-dot" aria-hidden="true"></span> : null}
                    {tx.location.days[key]}
                    {isToday ? (
                      <span class="ml-1 font-cond text-[9.5px] tracking-[0.25em] text-gold-soft">
                        · {tx.location.today}
                      </span>
                    ) : null}
                  </span>
                  <span class={isToday ? "text-gold" : "text-ink-dim"}>
                    {tx.location.hours[key]}
                  </span>
                </li>
              );
            })
          }
        </ul>

        <div class="mb-6 font-cond text-[11px] uppercase tracking-[0.22em] text-gold">
          {tx.location.contact}
        </div>

        <ul class="space-y-[14px] text-[14px]">
          <li class="flex flex-col">
            <span class="font-cond text-[10px] uppercase tracking-[0.22em] text-ink-mute">
              {tx.location.labels.address}
            </span>
            <span class="text-ink">{tx.location.address}</span>
          </li>
          <li class="flex flex-col">
            <span class="font-cond text-[10px] uppercase tracking-[0.22em] text-ink-mute">
              {tx.location.labels.email}
            </span>
            <a href={`mailto:${email}`} class="text-ink transition-colors hover:text-gold">
              {email}
            </a>
          </li>
          {whatsappUrl ? (
            <li class="flex flex-col">
              <span class="font-cond text-[10px] uppercase tracking-[0.22em] text-ink-mute">
                {tx.location.labels.whatsapp}
              </span>
              <a
                href={whatsappUrl}
                class="text-ink transition-colors hover:text-gold"
                target="_blank"
                rel="noopener noreferrer"
              >
                {whatsappDisplay}
              </a>
            </li>
          ) : null}
          {phone ? (
            <li class="flex flex-col">
              <span class="font-cond text-[10px] uppercase tracking-[0.22em] text-ink-mute">
                {tx.location.labels.phone}
              </span>
              <a href={`tel:${phone.replace(/\s+/g, "")}`} class="text-ink transition-colors hover:text-gold">
                {phone}
              </a>
            </li>
          ) : null}
          <li class="flex flex-col">
            <span class="font-cond text-[10px] uppercase tracking-[0.22em] text-ink-mute">
              {tx.location.labels.station}
            </span>
            <span class="text-ink">{tx.location.nearStation}</span>
          </li>
        </ul>

        <a
          href={mapsDirections}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-9 inline-flex items-center gap-2 border-b border-gold pb-1 font-cond text-[11px] uppercase tracking-[0.22em] text-gold transition-opacity hover:opacity-80"
        >
          {tx.location.directions}
        </a>
      </div>

      {/* Cookie-gated Google Maps embed */}
      <div class="relative min-h-[420px] border-line md:border-l" id="map-container">
        {/* Placeholder shown until cookie consent is given */}
        <div
          id="map-placeholder"
          class="absolute inset-0 flex flex-col items-center justify-center gap-6 bg-surface p-10"
        >
          <svg
            width="40"
            height="40"
            viewBox="0 0 40 40"
            fill="none"
            aria-hidden="true"
            class="text-gold"
          >
            <path
              d="M20 4C13.373 4 8 9.373 8 16c0 9 12 20 12 20s12-11 12-20c0-6.627-5.373-12-12-12zm0 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8z"
              fill="currentColor"
            />
          </svg>
          <div class="text-center">
            <p class="font-cond text-[13px] uppercase tracking-[0.2em] text-ink">
              {tx.location.address}
            </p>
            <p class="mt-1 font-cond text-[11px] uppercase tracking-[0.18em] text-ink-mute">
              Lelystad, Nederland
            </p>
          </div>
          {mapsEmbed ? (
            <button
              id="load-map-btn"
              class="btn btn-ghost text-[11px]"
              data-embed={mapsEmbed}
            >
              {mapLabels[lang]}
            </button>
          ) : (
            <a
              href={mapsDirections}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost text-[11px]"
            >
              {tx.location.directions}
              <span class="sr-only">(opens in new tab)</span>
            </a>
          )}
        </div>

        {/* Iframe injected by JS only after cookie consent */}
        <div id="map-frame-slot" class="absolute inset-0 hidden"></div>
      </div>
    </div>
  </div>
</section>

<div class="rule" aria-hidden="true"></div>

<script>
  function loadMap() {
    const placeholder = document.getElementById("map-placeholder");
    const slot = document.getElementById("map-frame-slot");
    const btn = document.getElementById("load-map-btn") as HTMLButtonElement | null;
    if (!placeholder || !slot) return;

    const embedSrc = btn?.dataset.embed ?? placeholder.dataset.embed ?? "";
    if (!embedSrc) return;

    placeholder.classList.add("hidden");
    slot.classList.remove("hidden");
    slot.innerHTML = `<iframe
      src="${embedSrc}"
      title="Barbershop The Brothers — De Promesse 113, Lelystad"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      class="absolute inset-0 h-full w-full"
      style="border:0; filter: grayscale(0.25) contrast(1.05)"
      aria-label="Map showing Barbershop The Brothers location"
    ></iframe>`;
  }

  function checkConsentAndLoad() {
    if (localStorage.getItem("cookie_consent") === "accepted") {
      loadMap();
    }
  }

  // Check on page load
  checkConsentAndLoad();

  // React to consent given during this session
  window.addEventListener("cookie-consent", (e) => {
    if ((e as CustomEvent).detail === "accepted") loadMap();
  });

  // Manual "Load map" button (grants implied consent for the map)
  document.getElementById("load-map-btn")?.addEventListener("click", () => {
    localStorage.setItem("cookie_consent", "accepted");
    window.dispatchEvent(new CustomEvent("cookie-consent", { detail: "accepted" }));
    loadMap();
  });
</script>
