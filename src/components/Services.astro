---
import { getTranslations, t, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const services = getTranslations(lang).services.items;
---

<section id="services" class="px-4 py-24 md:px-8" data-animate>
  <div class="mx-auto max-w-6xl">
    <h2 class="section-title section-title--left">{t(lang, "services.title")}</h2>
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <article class="group rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:border-gold/50 hover:bg-white/10 hover:shadow-2xl hover:shadow-gold/10">
            <h3 class="font-heading text-xl text-text-primary">{service.name}</h3>
            <p class="mt-3 text-sm text-text-secondary">{service.desc}</p>
            <p class="mt-6 text-2xl font-bold text-gold">{service.price}</p>
            <a
              href={`/${lang}/#booking`}
              class="mt-6 inline-flex rounded-full border border-gold px-5 py-2 text-sm font-semibold text-gold transition hover:bg-gold hover:text-bg"
            >
              {t(lang, "nav.bookNow")}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
