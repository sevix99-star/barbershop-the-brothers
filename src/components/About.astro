---
import { getTranslations, type Lang } from "../i18n/utils";
import { USP_ICONS } from "../config/services";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tx = getTranslations(lang);
const values = [tx.about.value1, tx.about.value2, tx.about.value3];
const numerals = ["I.", "II.", "III."];
---

<section id="about" class="sec" data-animate>
  <div class="wrap">
    <div class="sec-head">
      <div>
        <div class="sec-num">
          <span class="tick" aria-hidden="true"></span>
          <span>{tx.about.number} —</span>
          <span>{tx.about.eyebrow}</span>
        </div>
        <h2 class="mt-[18px]">
          <span>{tx.about.headline.part1}</span><br />
          <em>{tx.about.headline.accent}</em>
        </h2>
      </div>
      <p class="lede">{tx.about.lede}</p>
    </div>

    <div class="grid grid-cols-1 border-y border-line md:grid-cols-3">
      {
        values.map((value, idx) => (
          <div
            class={`usp-col relative px-10 py-14 ${idx < values.length - 1 ? "border-b border-line md:border-b-0 md:border-r" : ""}`}
          >
            <span class="absolute right-7 top-6 font-cond text-[10px] uppercase tracking-[0.2em] text-ink-mute">
              {numerals[idx]}
            </span>
            <div class="mb-7 h-[44px] text-gold" set:html={USP_ICONS[idx] ?? ""} />
            <h3 class="font-serif text-[26px] font-medium leading-tight tracking-[-0.01em] text-ink">
              {value.title}
            </h3>
            <p class="mt-3 max-w-[340px] text-[15px] leading-[1.65] text-ink-dim">
              {value.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<div class="rule" aria-hidden="true"></div>
