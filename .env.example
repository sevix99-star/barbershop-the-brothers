# ------------------------------------------------------------------
# Public client data. Every value is read in components via
# `import.meta.env.PUBLIC_*`. Leave blank to hide the feature — the
# components fall back gracefully so nothing empty is rendered.
# Never commit real values here; copy this file to `.env` locally or
# set the keys in Vercel → Project → Settings → Environment Variables.
# ------------------------------------------------------------------

# Fresha (or any) online-booking URL — opens in a new tab.
PUBLIC_BOOKING_URL=

# WhatsApp number in international format (e.g. +31612345678).
# Also used to render the `wa.me/` chat link in Booking + Location + Footer.
PUBLIC_WHATSAPP=

# Phone number — shown in Location contact list and injected into JSON-LD.
PUBLIC_PHONE=

# Business email — shown in Location contact list and injected into JSON-LD.
PUBLIC_EMAIL=

# Dutch Chamber of Commerce number (Kamer van Koophandel).
PUBLIC_KVK=

# Dutch VAT / BTW number.
PUBLIC_BTW=

# Social profile URLs (icons are hidden automatically when left blank).
PUBLIC_INSTAGRAM_URL=
PUBLIC_FACEBOOK_URL=
PUBLIC_TIKTOK_URL=

# Google Maps embed URL (iframe src, full embed URL with pb=… token).
PUBLIC_MAPS_EMBED=

# Link for "See all 109 reviews on Google" — usually your Google Place
# reviews URL (e.g. https://g.page/r/<place_id>).
PUBLIC_GOOGLE_REVIEWS_URL=
